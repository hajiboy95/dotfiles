[core]
	attributesfile = ~/.gitattributes
[pull]
	rebase = false
[filter "strip-notebook-output"]
	clean = ~/notebook_cleaning/.venv/bin/jupyter-nbconvert --ClearOutputPreprocessor.enabled=True --ClearMetadataPreprocessor.enabled=True --to=notebook --stdin --stdout --log-level=ERROR
[safe]
	directory = /opt/homebrew
